# Flask 服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=9924
FLASK_DEBUG=false

# AI 标注 API 配置
# 推理工具: lmstudio / vllm / ollama / aliyun
AI_INFERENCE_TOOL=lmstudio
AI_API_URL=http://localhost:1234/v1/chat/completions
AI_API_KEY=your-api-key-here
AI_MODEL=default-model

# 阿里云大模型配置 (使用 aliyun 时必填)
ALIYUN_API_KEY=your-aliyun-api-key
ALIYUN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ALIYUN_MODEL=qwen-vl-plus
