# Flask 服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=9924
FLASK_DEBUG=false

# AI 标注 API 配置
# 推理工具: lmstudio / vllm / ollama / openai / aliyun
AI_INFERENCE_TOOL=lmstudio
AI_API_URL=http://localhost:1234/v1/chat/completions
AI_API_KEY=your-api-key-here
AI_MODEL=default-model

# OpenAI 配置 (使用 openai 时)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4o-mini

# nndeploy-app 服务地址（docker-compose 内使用服务名，宿主机开发用 127.0.0.1）
NNDEPLOY_APP_URL=http://nndeploy-app:8002

# Deploy 容器配置（仅 deploy 服务使用）
SERVER_URL=http://xclabel-server:5000
CACHE_DIR=/app/cache
MAX_ENGINES=10

# 阿里云大模型配置 (使用 aliyun 时必填)
ALIYUN_API_KEY=your-aliyun-api-key
ALIYUN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ALIYUN_MODEL=qwen-vl-plus
